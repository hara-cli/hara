{
  "name": "@nanhara/hara",
  "version": "0.133.0",
  "description": "hara — a coding agent CLI that runs like an engineering org.",
  "bin": {
    "hara": "runtime-bootstrap.cjs"
  },
  "type": "module",
  "files": [
    "dist",
    "!dist/bin",
    "runtime-bootstrap.cjs",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "CLA.md",
    "plugins"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "llm",
    "agent-orchestration",
    "multi-agent",
    "anthropic",
    "claude"
  ],
  "license": "Apache-2.0",
  "author": "Nanhara",
  "homepage": "https://hara.run",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hara-cli/hara.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsc && node scripts/normalize-dist-modes.mjs && node scripts/check-local-bin-link.mjs",
    "prepare": "npm run build",
    "doctor:local-link": "node scripts/check-local-bin-link.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node runtime-bootstrap.cjs",
    "test": "npm run build && node --test --test-timeout=120000 test/*.test.mjs",
    "build:binary": "npm run build && bun scripts/build-binary.ts dist/bin/hara",
    "build:binaries": "npm run build && bun scripts/build-binary.ts dist/bin/hara-darwin-arm64 bun-darwin-arm64 && bun scripts/build-binary.ts dist/bin/hara-darwin-x64 bun-darwin-x64-baseline && bun scripts/build-binary.ts dist/bin/hara-linux-x64 bun-linux-x64-baseline && bun scripts/build-binary.ts dist/bin/hara-linux-arm64 bun-linux-arm64"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "ink": "^6.8.0",
    "openai": "^6.44.0",
    "react": "^19.2.7",
    "undici": "^7.28.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@zvec/zvec": "^0.5.0",
    "qrcode-terminal": "^0.12.0"
  },
  "overrides": {
    "@larksuiteoapi/node-sdk": {
      "axios": "1.18.1",
      "protobufjs": "7.6.5"
    },
    "@hono/node-server": "2.0.11",
    "hono": "4.12.31",
    "fast-uri": "3.1.4"
  }
}
